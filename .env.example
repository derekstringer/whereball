# SportStream Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# See docs/env.md for detailed documentation

# =============================================================================
# CORE SERVICES
# =============================================================================

# Supabase (Backend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # SERVER-SIDE ONLY

# RevenueCat (IAP/Subscriptions)
REVENUECAT_PUBLIC_KEY_IOS=appl_your-key-here
REVENUECAT_PUBLIC_KEY_ANDROID=goog_your-key-here
REVENUECAT_SECRET_KEY=sk_your-secret-here  # SERVER-SIDE ONLY

# =============================================================================
# AI & VOICE STACK (See docs/adr/0005-ai-and-voice-stack.md)
# =============================================================================

# Groq (Primary LLM) - SERVER-SIDE ONLY
GROQ_API_KEY=gsk_your-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# xAI Grok (Fallback LLM) - SERVER-SIDE ONLY
GROK_API_KEY=xai-your-key-here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-fast-reasoning

# Google Cloud TTS (Primary Voice) - SERVER-SIDE ONLY
GOOGLE_TTS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_TTS_DEFAULT_VOICE=en-US-Neural2-G

# ElevenLabs (Premium Voice - Optional) - SERVER-SIDE ONLY
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# =============================================================================
# AI/VOICE CONFIGURATION
# =============================================================================

# Feature Flags
AI_ROUTING_ENABLED=true
ROUTER_ESCALATE=false  # Set to true to enable Grok fallback
ELEVENLABS_ENABLED=false  # Set to true to enable premium voices
VOICE_CACHE_ENABLED=true

# Cost Guardrails
AI_MAX_TOKENS_PER_REQ=2000
AI_DAILY_BUDGET_USD=100
TTS_DAILY_BUDGET_USD=50

# Rate Limits (per user)
AI_FREE_TIER_DAILY_LIMIT=3
AI_PREMIUM_TIER_DAILY_LIMIT=30
AI_PREMIUM_TIER_MONTHLY_LIMIT=100

# TTS/Voice Settings
VOICE_PROVIDER=google  # Options: google | elevenlabs | device
VOICE_CACHE_BUCKET=sportstream-tts-cache
VOICE_DEFAULT_PERSONA=national_desk
VOICE_FREE_USES_CLOUD=false
VOICE_MAX_LEN_CHARS=600

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# PostHog (Events & Feature Flags)
POSTHOG_API_KEY=phc_your-key-here  # Safe for client-side
POSTHOG_HOST=https://app.posthog.com

# Sentry (Error Tracking - Optional)
SENTRY_DSN=https://your-key@sentry.io/your-project-id  # Safe for client-side
SENTRY_ORG=sportstream
SENTRY_PROJECT=whereball-mobile
SENTRY_AUTH_TOKEN=your-auth-token-here  # For CI/CD only

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# Sports Data
SPORTSDB_API_KEY=your-sportsdb-key-here  # Optional for paid tier
ESPN_SCRAPER_USER_AGENT=SportStream/1.0

# Ads (Free Tier)
ADMOB_APP_ID_IOS=ca-app-pub-your-id-here
ADMOB_APP_ID_ANDROID=ca-app-pub-your-id-here
ADMOB_BANNER_UNIT_ID=ca-app-pub-your-unit-id-here

# =============================================================================
# DEVELOPMENT / PRODUCTION
# =============================================================================

NODE_ENV=development  # development | production
API_BASE_URL=http://localhost:54321  # Local Supabase or production URL
DEBUG_MODE=true  # Set to false in production
SKIP_AUTH=false  # Set to true for local testing without login

# =============================================================================
# SECURITY NOTES
# =============================================================================

# ⚠️ NEVER COMMIT TO GIT:
# - .env.local
# - .env.production
# - google-services.json
# - GoogleService-Info.plist
#
# ✅ SAFE FOR CLIENT-SIDE:
# - SUPABASE_URL, SUPABASE_ANON_KEY
# - REVENUECAT_PUBLIC_KEY_*
# - POSTHOG_API_KEY
# - SENTRY_DSN
# - ADMOB_APP_ID_*
#
# 🔒 SERVER-SIDE ONLY:
# - SUPABASE_SERVICE_ROLE_KEY
# - REVENUECAT_SECRET_KEY
# - GROQ_API_KEY, GROK_API_KEY
# - GOOGLE_TTS_*, ELEVENLABS_API_KEY

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Fill in required values (see docs/env.md)
#
# 3. Add .env.local to .gitignore (should already be there)
#
# 4. Run the app:
#    npm run start
#
# For full documentation, see: docs/env.md
