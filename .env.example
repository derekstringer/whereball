# PawFinder Environment Variables
# Copy to .env.local and fill in your values

# RescueGroups.org API (optional — get your free key at https://rescuegroups.org/services/request-an-api-key/)
# When no key is set, the app automatically uses Austin Animal Center open data (free, no key needed)
EXPO_PUBLIC_RESCUEGROUPS_API_KEY=your-rescuegroups-api-key

# Cloudflare Worker for pet photos (scrapes real photos from 24PetConnect)
# Deploy: cd worker && npx wrangler deploy
EXPO_PUBLIC_PHOTO_WORKER_URL=https://pawfinder-photos.your-subdomain.workers.dev

# Supabase (optional — for user accounts & favorites sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
