# PawFinder Environment Variables
# Copy to .env.local and fill in your values

# Petfinder API (register at https://www.petfinder.com/developers/)
EXPO_PUBLIC_PETFINDER_API_KEY=your-petfinder-api-key
EXPO_PUBLIC_PETFINDER_API_SECRET=your-petfinder-api-secret

# Supabase (optional — for user accounts & favorites sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
